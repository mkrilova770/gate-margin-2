# Локально: скопируйте в .env
PORT=3000

# Gate (если используются подписанные запросы к API)
GATE_API_KEY=your_gate_api_key
GATE_API_SECRET=your_gate_api_secret

# KuCoin API (маржинальные borrow-данные)
KUCOIN_API_KEY=your_kucoin_api_key
KUCOIN_API_SECRET=your_kucoin_api_secret
KUCOIN_API_PASSPHRASE=your_kucoin_api_passphrase

# Опционально
# SCAN_SWR_TTL_MS=20000

# --- Railway (Variables в проекте, не коммитить) ---
# PORT задаётся платформой автоматически.
# Добавьте те же секреты: GATE_*, KUCOIN_*.
# CLI: railway login — токен хранится у CLI, в приложение не кладём.
